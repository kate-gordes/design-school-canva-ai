{
  "name": "canva-prototype",
  "description": "A boilerplate to rapidly prototype for Canva with AI and Easel.",
  "author": "Blake Kus <blake@canva.com>",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run format && NODE_ENV=development && vite --host",
    "start": "npm run dev",
    "build": "npm run format && NODE_ENV=production && npm run lint:check && npm run clean && vite build && rm -rf dist/.gitkeep",
    "preview": "npm run build && vite preview --host",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:check": "eslint . --max-warnings 1000",
    "fetch-agent-mds": "tsx scripts/fetch-agent-mds.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:e2e": "playwright test --config=playwright.dev.config.ts",
    "test:e2e:ui": "playwright test --config=playwright.dev.config.ts --ui",
    "test:e2e:headed": "playwright test --config=playwright.dev.config.ts --headed --project=chromium",
    "test:e2e:visual": "playwright test --config=playwright.dev.config.ts --headed --project=chromium --workers=1 --timeout=60000",
    "test:e2e:ci": "playwright test",
    "build:analyse": "npm run clean && ANALYSE=true vite build",
    "build:no-lint": "NODE_ENV=production && npm run clean && vite build && rm -rf dist/.gitkeep",
    "preview:no-lint": "npm run build:no-lint && vite preview --host",
    "prepare": "husky",
    "pre-commit": "lint-staged"
  },
  "dependencies": {
    "@canva-ct/auth": "latest",
    "@canva-ct/canva": "latest",
    "@canva-ct/connect": "^0.1.1",
    "@canva-ct/genai": "latest",
    "@canva/easel": "^22.0.0",
    "@posthog/react": "^1.8.1",
    "@tailwindcss/vite": "^4.1.11",
    "lucide-react": "^0.453.0",
    "posthog-js": "^1.354.3",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router": "6.30.0",
    "react-router-dom": "6.30.0",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@canva-ct/fox": "latest",
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.49.0",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^24.0.10",
    "@types/react": "^19.1.1",
    "@types/react-dom": "^19.1.1",
    "@vitejs/plugin-react": "^4.5.2",
    "dotenv": "^16.4.5",
    "eslint": "^9.29.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "mime-types": "^2.1.35",
    "postcss": "^8.5.2",
    "postcss-modules-values-replace": "^4.2.0",
    "postcss-values-parser": "^6.0.2",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.19.2",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.34.1",
    "vite": "^7.0.0",
    "vite-plugin-svgr": "^4.2.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "prettier --write"
    ],
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix --max-warnings 1000"
    ]
  }
}
